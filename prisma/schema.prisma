// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  PDF
  DOCUMENT
  OTHER
}

enum DealerType {
  AUTHORIZED
  FRANCHISE
  DISTRIBUTOR
  RETAIL
}

enum DealerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_RESET
  PERMISSION_DENIED
  OTHER
}

// ==========================================
// USER & AUTH
// ==========================================

model User {
  id            String     @id @default(cuid())
  name          String
  username      String?    @unique
  email         String     @unique
  password      String
  status        UserStatus @default(ACTIVE)
  phone         String?
  department    String?
  designation   String?
  employeeId    String?
  image         String?
  companyId     String?
  dealerId      String?
  isSystemAdmin Boolean    @default(false)
  forcePasswordChange Boolean @default(false)
  twoFactorEnabled    Boolean @default(false)
  timezone      String     @default("UTC")
  language      String     @default("en")
  lockedAt      DateTime?
  failedLoginAttempts Int    @default(0)
  lastLoginAt   DateTime?
  accountExpiresAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  company             Company?             @relation(fields: [companyId], references: [id])
  dealer              Dealer?              @relation(fields: [dealerId], references: [id])
  userRoles           UserRole[]
  userPermissions     UserPermission[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  posts               Post[]               @relation("PostAuthor")
  comments            Comment[]            @relation("CommentAuthor")
  loginHistories      LoginHistory[]
  visitingCards       VisitingCard[]       @relation("VisitingCardEmployee")
  createdVisitingCards VisitingCard[]      @relation("VisitingCardCreator")

  @@index([email])
  @@index([companyId])
  @@index([dealerId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ==========================================
// RBAC — Roles & Permissions
// ==========================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  displayName String?
  description String?
  isSystem    Boolean  @default(false) // System roles can't be deleted
  color       String?  // Optional hex/color name for badges
  priority    Int      @default(0)     // Higher priority roles override lower ones
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "users.create"
  label       String   // Human-readable label
  description String?
  group       String   // e.g., "users", "cms", "products"
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model UserPermission {
  id           String  @id @default(cuid())
  userId       String
  permissionId String
  value        Boolean @default(true) // true = allow, false = deny (override)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model LoginHistory {
  id            String   @id @default(cuid())
  userId        String
  ipAddress     String?
  userAgent     String?
  status        String   // e.g. "SUCCESS", "FAILED"
  failureReason String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ==========================================
// COMPANY & DEALER
// ==========================================

model Company {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  email       String?
  phone       String?
  address     String?
  logo        String?
  website     String?
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  users   User[]
  dealers Dealer[]
}

model Dealer {
  id               String       @id @default(cuid())

  // Basic Information
  name             String
  slug             String       @unique
  dealerCode       String       @unique
  businessName     String?
  dealerType       DealerType   @default(AUTHORIZED)
  status           DealerStatus @default(ACTIVE)

  // Contact Information
  contactPerson    String?
  designation      String?
  phone            String?      // Mobile
  whatsapp         String?
  landline         String?
  email            String?

  // Address
  address          String?
  city             String?
  district         String?
  province         String?
  country          String?      @default("Pakistan")
  postalCode       String?
  googleMapsUrl    String?

  // Business Details
  registrationNo   String?
  taxNo            String?
  yearsInBusiness  Int?

  // Products & Services (stored as JSON string arrays)
  products         Json?        // e.g. ["ELECTRIC_BIKES","PETROL_BIKES"]
  services         Json?        // e.g. ["SALES","SERVICE"]

  // Business Hours
  openingTime      String?
  closingTime      String?
  workingDays      Json?        // e.g. ["MON","TUE","WED"]

  // Social Links
  facebook         String?
  instagram        String?
  linkedin         String?
  youtube          String?
  website          String?

  // Uploads (URL strings — managed via Media Library)
  logo             String?
  coverImage       String?
  galleryImages    Json?        // string[]
  documents        Json?        // string[]

  // Notes
  internalNotes    String?      @db.Text
  publicNotes      String?      @db.Text

  // Meta
  companyId        String?
  isActive         Boolean      @default(true)
  deletedAt        DateTime?    // Soft delete
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  company          Company?     @relation(fields: [companyId], references: [id])
  users            User[]

  @@index([companyId])
  @@index([status])
  @@index([dealerType])
  @@index([city])
  @@index([deletedAt])
}

// ==========================================
// CMS — Content Management
// ==========================================

model ContentPage {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  keywords    String?
  isPublished Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  sections ContentSection[]
}

model ContentSection {
  id          String        @id @default(cuid())
  pageId      String
  key         String        // e.g., "hero", "about_mission"
  title       String?
  subtitle    String?
  content     String?       // Rich text or plain text
  imageUrl    String?
  videoUrl    String?
  ctaText     String?
  ctaLink     String?
  metadata    Json?         // Flexible JSON for extra fields
  order       Int           @default(0)
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  page ContentPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, key])
  @@index([pageId])
}

// ==========================================
// PRODUCTS
// ==========================================

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@index([parentId])
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  content     String?       @db.LongText // Rich text
  price       Decimal?      @db.Decimal(10, 2)
  sku         String?       @unique
  categoryId  String?
  brand       String?
  tags        Json?         // Changed to Json for MySQL
  images      Json?         // Changed to Json for MySQL
  thumbnail   String?
  isFeatured  Boolean       @default(false)
  status      ContentStatus @default(DRAFT)
  sortOrder   Int           @default(0)
  metaTitle   String?
  metaDesc    String?
  deletedAt   DateTime?     // Soft delete
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category Category? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
}

// ==========================================
// MEDIA LIBRARY
// ==========================================

model Media {
  id           String       @id @default(cuid())
  filename     String
  originalName String
  url          String
  mimeType     String
  size         Int
  type         MediaType
  width        Int?         // Image width
  height       Int?         // Image height
  duration     Float?       // Video duration
  altText      String?
  caption      String?
  description  String?      @db.Text
  tags         Json?        // string[] tags
  uploadedBy   String?
  folderId     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  folder       MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  usages       MediaUsage[]

  @@index([type])
  @@index([folderId])
}

model MediaFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent    MediaFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaFolder[] @relation("FolderHierarchy")
  media     Media[]

  @@unique([name, parentId])
  @@index([parentId])
}

model MediaUsage {
  id         String   @id @default(cuid())
  mediaId    String
  entity     String   // e.g. "Product", "Dealer", "ContentSection", "Post", "User"
  entityId   String   // primary key of the using entity
  fieldName  String?  // e.g. "thumbnail", "image", "logo"
  createdAt  DateTime @default(now())

  media      Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, entity, entityId, fieldName])
  @@index([mediaId])
  @@index([entity, entityId])
}

// ==========================================
// SETTINGS
// ==========================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?  @db.Text
  type      String   @default("text") // text, json, boolean, number
  group     String   @default("general") // general, seo, social, email
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, warning, error, success
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ==========================================
// AUDIT & ACTIVITY LOGS
// ==========================================

model ActivityLog {
  id         String    @id @default(cuid())
  userId     String?
  action     LogAction
  entity     String?   // e.g., "User", "Product"
  entityId   String?
  description String
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String?
  action    LogAction
  entity    String
  entityId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ==========================================
// CAPTCHA SYSTEM
// ==========================================

model CaptchaSession {
  id        String   @id @default(cuid())
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model CaptchaLockout {
  id          String   @id @default(cuid())
  identifier  String   @unique
  attempts    Int      @default(0)
  lockedUntil DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// NEW CMS ENTITIES
// ==========================================

model Menu {
  id        String     @id @default(cuid())
  name      String     // e.g. "Main Menu", "Footer Policies"
  slug      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items     MenuItem[]
}

model MenuItem {
  id        String   @id @default(cuid())
  menuId    String
  label     String   // The text to display
  url       String?  // The URL it points to (could be internal or external)
  parentId  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  icon      String?
  target    String?  @default("_self")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu      Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent    MenuItem?  @relation("MenuChildren", fields: [parentId], references: [id])
  children  MenuItem[] @relation("MenuChildren")

  @@index([menuId])
  @@index([parentId])
}

model PostCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts       Post[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  posts     Post[]   @relation("PostToTag")
}

model Post {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String?       @db.LongText // Use LongText for rich content
  featuredImg String?
  authorId    String?
  categoryId  String?
  status      ContentStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)
  metaTitle   String?
  metaDesc    String?
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author      User?         @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  category    PostCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags        Tag[]         @relation("PostToTag")
  comments    Comment[]

  @@index([status])
  @@index([categoryId])
  @@index([authorId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String?
  name      String?
  email     String?
  content   String
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User?    @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([postId])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String?  // Designation or company
  company     String?
  avatar      String?
  rating      Int      @default(5)
  content     String   @db.Text
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FaqCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  faqs        FaqItem[]
}

model FaqItem {
  id          String       @id @default(cuid())
  categoryId  String?
  question    String
  answer      String       @db.Text
  order       Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  category    FaqCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}

model GalleryAlbum {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  isActive    Boolean        @default(true)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  images      GalleryImage[]
}

model GalleryImage {
  id          String        @id @default(cuid())
  albumId     String
  url         String
  altText     String?
  caption     String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())

  album       GalleryAlbum  @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
}

// ==========================================
// COMPANY MODULE
// ==========================================

// Single-document store for all About Us sections.
// Each row = one named section (key = "hero" | "mission" | "vision" | etc.)
// Data is stored as flexible JSON so each section can have its own shape.
model AboutSection {
  id        String   @id @default(cuid())
  key       String   @unique // hero | intro | mission | vision | story | why_us | stats | gallery | seo
  data      Json     // Section-specific structured object
  updatedAt DateTime @updatedAt

  @@index([key])
}

model TeamMember {
  id            String    @id @default(cuid())
  name          String
  position      String?
  department    String?
  biography     String?   @db.Text
  experience    String?
  qualification String?
  email         String?
  phone         String?
  linkedin      String?
  facebook      String?
  instagram     String?
  twitter       String?
  photo         String?
  coverImage    String?
  order         Int       @default(0)
  isFeatured    Boolean   @default(false)
  isActive      Boolean   @default(true)
  joiningDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive])
  @@index([order])
  @@index([department])
}

model Career {
  id               String    @id @default(cuid())
  title            String
  department       String?
  location         String?
  employmentType   String?   // FULL_TIME | PART_TIME | CONTRACT | INTERNSHIP | REMOTE
  experience       String?
  salaryRange      String?
  description      String?   @db.LongText
  responsibilities String?   @db.LongText
  requirements     String?   @db.LongText
  skills           String?   @db.Text
  benefits         String?   @db.Text
  deadline         DateTime?
  applyEmail       String?
  applyUrl         String?
  status           String    @default("DRAFT") // DRAFT | PUBLISHED | CLOSED
  metaTitle        String?
  metaDesc         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([department])
  @@index([location])
  @@index([employmentType])
}

// ==========================================
// VISITING CARD GENERATOR MODULE
// ==========================================

model VisitingCardTemplate {
  id              String   @id @default(cuid())
  name            String
  templateType    String   @default("MODERN") // CLASSIC | MODERN | CORPORATE | MINIMAL | DARK | PREMIUM | VERTICAL | HORIZONTAL
  primaryColor    String   @default("#D72626")
  secondaryColor  String   @default("#1E1E1E")
  backgroundColor String   @default("#0F0F11")
  textColor       String   @default("#FFFFFF")
  fontFamily      String   @default("Inter")
  fontSize        String   @default("medium")
  borderRadius    String   @default("16px")
  logoPosition    String   @default("center")
  qrPosition      String   @default("bottom-right")
  iconStyle       String   @default("circle")
  isDefault       Boolean  @default(false)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  visitingCards   VisitingCard[]
}

model VisitingCard {
  id             String                @id @default(cuid())
  cardName       String
  employeeId     String?
  templateId     String?
  fullName       String
  designation    String?
  department     String?
  employeeCode   String?
  phone          String?
  whatsapp       String?
  email          String?
  extension      String?
  qrCodeType     String                @default("VCARD") // VCARD | WEBSITE | WHATSAPP | EMAIL | CUSTOM
  qrCodeValue    String?               @db.Text
  customQrUrl    String?
  profilePhoto   String?
  companyName    String?
  companyLogo    String?
  website        String?
  address        String?
  frontBgType    String                @default("POLYGON")
  backBgType     String                @default("LIGHT_POLYGON")
  status         String                @default("ACTIVE")
  createdBy      String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  employee       User?                 @relation("VisitingCardEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  creator        User?                 @relation("VisitingCardCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  template       VisitingCardTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([templateId])
  @@index([status])
}

