// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-TENANCY & AUTHENTICATION
// ============================================================================

model Tenant {
  id                String    @id @default(cuid())
  companyName       String
  subscriptionTier  String    @default("pro") // free, pro, enterprise
  status            String    @default("active") // active, suspended, inactive
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users             User[]
  roles             Role[]
  auditLogs         AuditLog[]

  @@index([status])
  @@map("tenants")
}

model User {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  email             String
  passwordHash      String
  firstName         String?
  lastName          String?
  roleId            String?
  role              Role?     @relation(fields: [roleId], references: [id])
  
  status            String    @default("active") // active, inactive, suspended
  twoFAEnabled      Boolean   @default(false)
  twoFASecret       String?
  lastLogin         DateTime?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  auditLogs         AuditLog[]
  loginLogs         LoginLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([status])
  @@map("users")
}

model Role {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name              String    // Admin, Manager, Salesman, Accountant, BranchManager
  description       String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users             User[]
  permissions       Permission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id                String    @id @default(cuid())
  roleId            String
  role              Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  resource          String    // users, vehicles, inventory, sales, etc.
  action            String    // create, read, update, delete

  @@unique([roleId, resource, action])
  @@index([roleId])
  @@map("permissions")
}

model AuditLog {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
  
  entityType        String    // users, vehicles, sales_invoices, etc.
  entityId          String?   // ID of the entity that was changed
  action            String    // create, update, delete
  
  oldValues         Json?
  newValues         Json?
  changeReason      String?
  
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([entityType])
  @@map("audit_logs")
}

model LoginLog {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  loginTime         DateTime  @default(now())
  ipAddress         String?
  deviceInfo        String?
  success           Boolean   @default(true)
  failureReason     String?

  @@index([userId, loginTime])
  @@map("login_logs")
}

// ============================================================================
// VEHICLE INVENTORY MANAGEMENT
// ============================================================================

model Vehicle {
  id                String    @id @default(cuid())
  tenantId          String
  
  modelId           String
  model             VehicleModel @relation(fields: [modelId], references: [id])
  
  chassisNumber     String    @unique
  motorNumber       String    @unique
  
  status            String    @default("available") // available, reserved, sold, claimed
  purchasePrice     Float
  sellingPrice      Float?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  battery           VehicleBattery?
  salesInvoice      SalesInvoice?

  @@index([tenantId])
  @@index([status])
  @@index([modelId])
  @@map("vehicles")
}

model VehicleModel {
  id                String    @id @default(cuid())
  tenantId          String
  
  name              String    // Model name
  specifications    Json?     // Detailed specs in JSON
  basePrice         Float
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  vehicles          Vehicle[]

  @@index([tenantId])
  @@map("vehicle_models")
}

model VehicleBattery {
  id                String    @id @default(cuid())
  vehicleId         String    @unique
  vehicle           Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  serialNumber      String    @unique
  type              String    // graphene, lithium
  capacity          Float?    // kWh
  warrantyExpiry    DateTime?
  status            String    @default("active") // active, replaced, claimed, warranty_expired
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  batteryHistory    BatteryHistory[]

  @@index([vehicleId])
  @@index([status])
  @@map("vehicle_batteries")
}

model BatteryHistory {
  id                String    @id @default(cuid())
  batteryId         String
  battery           VehicleBattery @relation(fields: [batteryId], references: [id], onDelete: Cascade)
  
  fromVehicleId     String?
  toVehicleId       String?
  action            String    // assigned, replaced, claimed, exchanged
  reason            String?
  
  createdAt         DateTime  @default(now())

  @@index([batteryId])
  @@index([createdAt])
  @@map("battery_history")
}

// ============================================================================
// SPARE PARTS INVENTORY
// ============================================================================

model SparePart {
  id                String    @id @default(cuid())
  tenantId          String
  
  category          String    // Battery, Tires, Brakes, Electronics, etc.
  sku               String    @unique
  name              String
  description       String?
  
  supplier          String?
  unitPrice         Float
  reorderLevel      Int
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  inventory         SparePartInventory[]
  history           SparePartHistory[]

  @@index([tenantId])
  @@index([category])
  @@map("spare_parts")
}

model SparePartInventory {
  id                String    @id @default(cuid())
  partId            String
  part              SparePart @relation(fields: [partId], references: [id], onDelete: Cascade)
  
  quantityAvailable Int       @default(0)
  quantityReserved  Int       @default(0)
  lastStockCheck    DateTime?
  
  @@unique([partId])
  @@index([partId])
  @@map("spare_part_inventory")
}

model SparePartHistory {
  id                String    @id @default(cuid())
  partId            String
  part              SparePart @relation(fields: [partId], references: [id], onDelete: Cascade)
  
  transactionType   String    // in, out, transfer, adjustment
  quantity          Int
  referenceId       String?   // PO, SO, Transfer ID
  notes             String?
  
  createdAt         DateTime  @default(now())

  @@index([partId])
  @@index([createdAt])
  @@map("spare_part_history")
}

// ============================================================================
// CUSTOMERS & DEALERS
// ============================================================================

model Customer {
  id                String    @id @default(cuid())
  tenantId          String
  
  name              String
  cnic              String    @unique
  email             String?
  phone             String
  address           String?
  
  outstandingBalance Float   @default(0)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  customerVehicles  CustomerVehicle[]
  salesInvoices     SalesInvoice[]
  warrantyC laims    WarrantyClaim[]

  @@index([tenantId])
  @@index([cnic])
  @@map("customers")
}

model CustomerVehicle {
  id                String    @id @default(cuid())
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  vehicleId         String
  purchaseDate      DateTime
  warrantyExpiry    DateTime?
  
  createdAt         DateTime  @default(now())

  @@index([customerId])
  @@map("customer_vehicles")
}

model Dealer {
  id                String    @id @default(cuid())
  tenantId          String
  
  name              String
  contactPerson     String
  email             String?
  phone             String
  address           String?
  
  creditLimit       Float     @default(0)
  currentOutstanding Float   @default(0)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  dealerOrders      DealerOrder[]
  dealerLedger      DealerLedger[]

  @@index([tenantId])
  @@map("dealers")
}

model DealerOrder {
  id                String    @id @default(cuid())
  dealerId          String
  dealer            Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  
  orderDate         DateTime  @default(now())
  totalAmount       Float
  status            String    @default("pending") // pending, fulfilled, cancelled
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([dealerId])
  @@index([status])
  @@map("dealer_orders")
}

model DealerLedger {
  id                String    @id @default(cuid())
  dealerId          String
  dealer            Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  
  transactionType   String    // debit, credit
  amount            Float
  referenceId       String?   // Invoice or Order ID
  narration         String?
  
  transactionDate   DateTime  @default(now())

  @@index([dealerId])
  @@index([transactionDate])
  @@map("dealer_ledger")
}

// ============================================================================
// SALES & INVOICING
// ============================================================================

model SalesInvoice {
  id                String    @id @default(cuid())
  tenantId          String
  
  invoiceNumber     String    @unique
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id])
  
  vehicleId         String?   @unique
  vehicle           Vehicle?  @relation(fields: [vehicleId], references: [id])
  
  saleDate          DateTime  @default(now())
  totalAmount       Float
  discountAmount    Float     @default(0)
  paymentStatus     String    @default("pending") // pending, paid, partial
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  payments          Payment[]
  deliveryNote      DeliveryNote?

  @@index([tenantId])
  @@index([customerId])
  @@index([paymentStatus])
  @@map("sales_invoices")
}

model Payment {
  id                String    @id @default(cuid())
  invoiceId         String
  invoice           SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  amount            Float
  paymentMethod     String    // cash, check, transfer, credit_card
  paymentDate       DateTime  @default(now())
  bankReference     String?
  notes             String?
  
  @@index([invoiceId])
  @@index([paymentDate])
  @@map("payments")
}

model DeliveryNote {
  id                String    @id @default(cuid())
  invoiceId         String    @unique
  invoice           SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  deliveryDate      DateTime  @default(now())
  driverName        String?
  deliveredBy       String?
  signProofUrl      String?
  notes             String?
  
  createdAt         DateTime  @default(now())

  @@index([invoiceId])
  @@map("delivery_notes")
}

// ============================================================================
// WARRANTY & CLAIMS
// ============================================================================

model WarrantyClaim {
  id                String    @id @default(cuid())
  tenantId          String
  
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  vehicleId         String?
  claimType         String    // battery, vehicle, parts
  filedDate         DateTime  @default(now())
  status            String    @default("pending") // pending, under_review, approved, rejected, resolved
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  claimDocuments    ClaimDocument[]
  claimWorkflow     ClaimWorkflow[]
  claimResolutions  ClaimResolution[]

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@map("warranty_claims")
}

model ClaimDocument {
  id                String    @id @default(cuid())
  claimId           String
  claim             WarrantyClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  
  documentType      String    // receipt, video, photo, report
  fileUrl           String
  uploadedAt        DateTime  @default(now())
  
  @@index([claimId])
  @@map("claim_documents")
}

model ClaimWorkflow {
  id                String    @id @default(cuid())
  claimId           String
  claim             WarrantyClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  
  stage             String    // submitted, reviewed, approved, fulfilled, rejected
  assignedTo        String?
  notes             String?
  
  createdAt         DateTime  @default(now())

  @@index([claimId])
  @@map("claim_workflow")
}

model ClaimResolution {
  id                String    @id @default(cuid())
  claimId           String
  claim             WarrantyClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  
  resolutionType    String    // replacement, refund, repair, warranty_extended
  issuedDate        DateTime  @default(now())
  cost              Float?
  notes             String?
  
  @@index([claimId])
  @@map("claim_resolutions")
}

// ============================================================================
// NOTIFICATIONS & SYSTEM
// ============================================================================

model Notification {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  
  type              String    // low_stock, pending_claim, payment_due, credit_limit_warning, warranty_expiry
  message           String
  isRead            Boolean   @default(false)
  
  createdAt         DateTime  @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model SystemSetting {
  id                String    @id @default(cuid())
  tenantId          String
  
  key               String    // dark_mode, printer_config, etc.
  value             String
  
  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("system_settings")
}
