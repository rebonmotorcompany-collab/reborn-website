{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node server.js",
    "prebuild": "node -e \"const fs = require('fs'); fs.rmSync('public/_next', { recursive: true, force: true });\"",
    "build": "npm run db:push && npm run db:seed && next build --webpack",
    "build:hostinger": "npm run db:push && next build --webpack && node copy-static.js",
    "postbuild": "node copy-static.js",
    "postinstall": "prisma generate",
    "start": "node server.js",
    "lint": "next lint",
    "db:generate": "cross-env PRISMA_CLIENT_ENGINE_TYPE=library PRISMA_CLI_QUERY_ENGINE_TYPE=library prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@tiptap/extension-image": "^3.27.4",
    "@tiptap/extension-link": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "postcss": "^8.5.19",
    "prisma": "^5.22.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "yup": "^1.7.1",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}